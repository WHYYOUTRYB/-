---
interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocItem[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="toc" aria-label="目录">
    <button class="toc-toggle" type="button" aria-expanded="true">
      目录
    </button>
    <ol class="toc-list">
      {filtered.map((h) => (
        <li class={`toc-depth-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }
  .toc-toggle {
    display: none;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0;
    color: var(--color-text);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li {
    margin: 0.35rem 0;
  }
  .toc-list a {
    color: var(--color-text-soft);
    text-decoration: none;
  }
  .toc-list a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .toc-depth-3 {
    padding-left: 1.25rem;
  }

  /* 移动端：目录可收起 */
  @media (max-width: 768px) {
    .toc-toggle {
      display: block;
    }
    .toc-list {
      display: none;
      margin-top: 0.75rem;
    }
    .toc-toggle[aria-expanded="true"] + .toc-list {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".toc-toggle");
  if (toggle) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
    });
  }
</script>