---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const essays = await getCollection("essays", ({ data }) => !data.draft);
const sorted = essays.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="随笔" description="随笔与随想">
  <div class="page">
    <header class="page-header">
      <h1>随笔</h1>
      <p class="page-desc">偶尔写点什么。</p>
    </header>

    <ul class="item-list">
      {sorted.map((essay) => (
        <li class="item">
          <a href={`/essays/${essay.id}`}>{essay.data.title}</a>
          <span class="item-meta">{essay.data.pubDate.toLocaleDateString("zh-CN")}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 2.5rem 1.5rem;
  }
  .page-header {
    margin-bottom: 2rem;
  }
  .page-header h1 {
    font-size: 1.8rem;
    margin: 0 0 0.25rem;
    font-weight: 700;
  }
  .page-desc {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 0.95rem;
  }
  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .item:last-child {
    border-bottom: none;
  }
  .item a {
    color: var(--color-text);
    font-weight: 500;
  }
  .item-meta {
    font-size: 0.8rem;
    color: var(--color-text-faint);
  }
</style>