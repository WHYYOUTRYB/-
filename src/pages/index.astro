---
import BaseLayout from "../layouts/BaseLayout.astro";
import SubjectCard from "../components/SubjectCard.astro";
import { subjects } from "../content/subjects.config";
import { getAllNotes, countBySubject, getRecentNotes, getSubjectName } from "../lib/notes";

const allNotes = await getAllNotes();
const recentNotes = getRecentNotes(allNotes, 5);
---

<BaseLayout title="个人笔记" description="以学业笔记为核心的个人知识站点">
  <div class="home">
    <!-- Hero -->
    <section class="hero">
      <h1 class="hero-title">学业笔记</h1>
      <p class="hero-sub">以学科为纲，章节为目，记录所学。</p>
    </section>

    <!-- 学科卡片 -->
    <section class="section">
      <h2 class="section-title">学科</h2>
      <div class="subject-grid">
        {subjects.map((s) => (
          <SubjectCard subject={s} noteCount={countBySubject(allNotes, s.slug)} />
        ))}
      </div>
    </section>

    <!-- 最近笔记 -->
    {recentNotes.length > 0 && (
      <section class="section">
        <h2 class="section-title">最近笔记</h2>
        <ul class="recent-list">
          {recentNotes.map((note) => (
            <li class="recent-item">
              <a href={`/notes/${note.data.subject}/${note.id}`}>
                {note.data.title}
              </a>
              <span class="recent-meta">
                {getSubjectName(note.data.subject)} · {note.data.pubDate.toLocaleDateString("zh-CN")}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .home {
    padding: 2.5rem 1.5rem;
  }
  .hero {
    margin-bottom: 3rem;
  }
  .hero-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .hero-sub {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 1.1rem;
  }
  .section {
    margin-bottom: 2.5rem;
  }
  .section-title {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .subject-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .recent-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }
  .recent-item:last-child {
    border-bottom: none;
  }
  .recent-item a {
    color: var(--color-text);
    font-weight: 500;
  }
  .recent-meta {
    font-size: 0.8rem;
    color: var(--color-text-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>